@startuml B-SSAHTY Class Diagram

skinparam class {
    BackgroundColor White
    BorderColor Orange
    ArrowColor Gray
}

' ========================
' ENUMS
' ========================
enum UserRole {
    ATHLETE
    ADMIN
}

enum SpotStatus {
    PENDING
    APPROVED
    REJECTED
}

enum ReactionType {
    LIKE
    LOVE
    LAUGH
    SAD
}

enum FriendshipStatus {
    PENDING
    ACCEPTED
    REJECTED
}

' ========================
' MODELS
' ========================

package "User Management" {
    class User {
        +id: BigInt
        +name: String
        +email: String
        +role: UserRole
        +avatar_url: String
        +city: String
        +sports: JSON
        +isBanned: Boolean
        +last_online_at: DateTime
    }
    
    class Friendship {
        +id: BigInt
        +status: FriendshipStatus
        +user_id: BigInt
        +friend_id: BigInt
    }
}

package "Community & Social" {
    class Question {
        +id: BigInt
        +content: Text
        +category: String
        +user_id: BigInt
    }

    class Comment {
        +id: BigInt
        +content: Text
        +user_id: BigInt
        +question_id: BigInt
    }

    class Reaction {
        +id: BigInt
        +type: ReactionType
        +user_id: BigInt
        +reactable_id: BigInt
        +reactable_type: String
    }
}

package "Events & Locations" {
    class Spot {
        +id: BigInt
        +name: String
        +description: Text
        +latitude: Decimal
        +longitude: Decimal
        +address: String
        +image: String
        +status: SpotStatus
        +created_by: BigInt
    }

    class Event {
        +id: BigInt
        +title: String
        +description: Text
        +date: Date
        +time: Time
        +latitude: Decimal
        +longitude: Decimal
        +max_participants: Integer
        +user_id: BigInt
        +image: String
    }
}

package "Communication" {
    class Conversation {
        +id: BigInt
        +created_at: DateTime
    }

    class Message {
        +id: BigInt
        +content: Text
        +is_read: Boolean
        +user_id: BigInt
        +conversation_id: BigInt
    }

    class Notification {
        +id: UUID
        +type: String
        +data: JSON
        +read_at: DateTime
    }
}

' ========================
' RELATIONSHIPS
' ========================

' User Relationships
User "1" -- "*" Question : "creates"
User "1" -- "*" Comment : "writes"
User "1" -- "*" Reaction : "reacts"
User "1" -- "*" Spot : "proposes"
User "1" -- "*" Event : "organizes"
User "1" -- "*" Message : "sends"
User "1" -- "*" Friendship : "initiates/receives"
User "1" -- "*" Notification : "receives"

' Social Relationships
Question "1" -- "*" Comment : "has"
Question "1" -- "*" Reaction : "has (polymorphic)"
Comment "1" -- "*" Reaction : "has (polymorphic)"

' Event Relationships
Event "*" -- "*" User : "participants"
Event "1" -- "*" Reaction : "has (polymorphic)"

' Chat Relationships
Conversation "1" -- "*" Message : "contains"
Conversation "*" -- "*" User : "participants"

@enduml