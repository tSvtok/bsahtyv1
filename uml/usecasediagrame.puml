@startuml

left to right direction

actor Guest
actor User
actor Admin

User --|> Guest
Admin --|> User

rectangle "B-SSAHTY Platform" {

  (Register)
  (Login)

  (Edit Profile)
  (View Feed)
  (Post)
  (Comment)
  (Like)

  (add Friends)
  (Chat)

  (Map & Spots)
  (Create Spot)

  (Create Event)
  (Join Event)

  (Admin Panel)
  (Approve Spots)
  (Ban Users)
}

' --- Guest ---
Guest --> (Register)
Guest --> (Login)

' --- User ---
User --> (Edit Profile)
User --> (View Feed)
User --> (Post)
User --> (Comment)
User --> (Like)
User --> (add Friends)
User --> (Chat)
User --> (Map & Spots)
User --> (Create Spot)
User --> (Create Event)
User --> (Join Event)

' --- Admin ---
Admin --> (Admin Panel)
Admin --> (Approve Spots)
Admin --> (Ban Users)

' --- simple rule note ---
note right of (add Friends)
  A user can't add
  the same friend twice
end note

@enduml